# =============================================================================
# CONFIGURACAO DE AMBIENTE - Entrega Pra Mim
# =============================================================================
# IMPORTANTE: Copie este arquivo para .env e configure os valores
# NUNCA commite o arquivo .env com valores reais!
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de Dados MySQL
# -----------------------------------------------------------------------------
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/NOME_BANCO
# Em producao, use senhas fortes e usuario nao-root
DATABASE_URL="mysql://usuario:senha_forte_aqui@localhost:3306/entrega_pra_mim"

# -----------------------------------------------------------------------------
# NextAuth.js
# -----------------------------------------------------------------------------
# URL base da aplicacao (sem barra no final)
NEXTAUTH_URL="http://localhost:3000"

# Chave secreta para assinar tokens JWT
# OBRIGATORIO: Gere uma chave segura com: openssl rand -base64 32
# NUNCA use valores como "secret", "development", etc em producao
NEXTAUTH_SECRET="GERE_COM_openssl_rand_-base64_32"

# -----------------------------------------------------------------------------
# Google Maps API
# -----------------------------------------------------------------------------
# Obtenha suas chaves em: https://console.cloud.google.com/
# Recomendado: Use chaves diferentes para servidor e cliente
# Configure restricoes de dominio/IP no console do Google Cloud

# Chave do servidor (nao exposta ao cliente)
GOOGLE_MAPS_API_KEY="sua_chave_servidor_aqui"

# Chave do cliente (exposta ao navegador - configure restricoes de dominio!)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="sua_chave_cliente_aqui"

# -----------------------------------------------------------------------------
# Pagamentos (Opcional - para integracao com gateway)
# -----------------------------------------------------------------------------
# Secret para validacao de webhooks do gateway de pagamento
# PAYMENT_WEBHOOK_SECRET="seu_webhook_secret_aqui"

# -----------------------------------------------------------------------------
# DICAS DE SEGURANCA
# -----------------------------------------------------------------------------
# 1. Use senhas fortes e unicas para cada ambiente
# 2. Configure restricoes nas chaves de API (dominio, IP)
# 3. Rotacione secrets periodicamente
# 4. Nunca compartilhe ou commite arquivos .env
# 5. Use servicos de secrets management em producao (AWS Secrets Manager, etc)

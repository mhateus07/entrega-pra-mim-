# ===========================================
# CONFIGURAÇÃO DE PRODUÇÃO - Entrega Pra Mim
# ===========================================
# Copie este arquivo para .env no servidor
# e preencha com seus valores reais

# Banco de dados MySQL
DATABASE_URL="mysql://entrega_user:SENHA_SEGURA@localhost:3306/entrega_pra_mim"

# NextAuth.js
NEXTAUTH_URL="https://seudominio.com.br"
NEXTAUTH_SECRET="gere_uma_chave_secreta_com_openssl_rand_base64_32"

# Google Maps API
GOOGLE_MAPS_API_KEY="sua_chave_google_maps_servidor"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="sua_chave_google_maps_cliente"

# Ambiente
NODE_ENV="production"

# ==========================================
# OPCIONAL: Integrações de Pagamento
# ==========================================

# Mercado Pago
# MERCADOPAGO_ACCESS_TOKEN="seu_token"
# MERCADOPAGO_PUBLIC_KEY="sua_public_key"

# Stripe
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_PUBLIC_KEY="pk_live_..."

# Webhook Secret (para confirmar pagamentos)
# PAYMENT_WEBHOOK_SECRET="seu_webhook_secret"

# ==========================================
# DICAS DE SEGURANÇA
# ==========================================
# 1. Nunca commite este arquivo no Git
# 2. Use senhas fortes geradas aleatoriamente
# 3. Gere NEXTAUTH_SECRET com: openssl rand -base64 32
# 4. Restrinja acesso ao banco de dados
